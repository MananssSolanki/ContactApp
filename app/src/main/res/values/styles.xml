<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.ContactApp.Base" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="TextAppearance.ContactApp.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">34sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="TextAppearance.ContactApp.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="TextAppearance.ContactApp.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="TextAppearance.ContactApp.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="TextAppearance.ContactApp.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="TextAppearance.ContactApp.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="TextAppearance.ContactApp.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="TextAppearance.ContactApp.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="TextAppearance.ContactApp.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="TextAppearance.ContactApp.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/brand_text_primary</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextAppearance.ContactApp.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/brand_text_primary</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="TextAppearance.ContactApp.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/brand_text_secondary</item>
    </style>

    <style name="TextAppearance.ContactApp.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.ContactApp.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.ContactApp.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">@font/tasa</item>
        <item name="android:fontFamily">@font/tasa</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Widget.ContactApp.TextView" parent="@android:style/Widget.TextView">
        <item name="android:fontFamily">@font/tasa</item>
        <item name="fontFamily">@font/tasa</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="Widget.ContactApp.Toolbar" parent="@style/Widget.AppCompat.Toolbar">
        <item name="android:background">@color/brand_background</item>
        <item name="titleTextAppearance">@style/TextAppearance.ContactApp.TitleLarge</item>
        <item name="subtitleTextAppearance">@style/TextAppearance.ContactApp.BodySmall</item>
        <item name="contentInsetStartWithNavigation">0dp</item>
        <item name="contentInsetStart">0dp</item>
        <item name="contentInsetEnd">0dp</item>
        <item name="android:minHeight">72dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.ContactApp.TabLayout" parent="@style/Widget.Material3.TabLayout">
        <item name="tabTextAppearance">@style/TextAppearance.ContactApp.LabelLarge</item>
        <item name="tabTextColor">@color/brand_text_secondary</item>
        <item name="tabSelectedTextColor">@color/brand_text_inverse</item>
        <item name="tabIndicatorColor">@android:color/transparent</item>
        <item name="tabRippleColor">@color/brand_ripple_light</item>
        <item name="tabIndicatorAnimationMode">elastic</item>
        <item name="tabBackground">@android:color/transparent</item>
    </style>

    <style name="Widget.ContactApp.MaterialCardView" parent="@style/Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/brand_surface</item>
        <item name="strokeColor">@color/brand_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">1dp</item>
    </style>

    <style name="Widget.ContactApp.Button.Base" parent="@style/Widget.Material3.Button">
        <item name="android:fontFamily">@font/tasa</item>
        <item name="fontFamily">@font/tasa</item>
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.ContactApp.Button.Primary" parent="@style/Widget.ContactApp.Button.Base">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/brand_text_inverse</item>
        <item name="iconTint">@color/brand_text_inverse</item>
    </style>

    <style name="Widget.ContactApp.Button.Secondary" parent="@style/Widget.ContactApp.Button.Base">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/brand_text_primary</item>
    </style>

    <style name="Widget.ContactApp.Button.Dark" parent="@style/Widget.ContactApp.Button.Base">
        <item name="android:background">@drawable/bg_button_dark</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/brand_text_inverse</item>
    </style>

    <style name="Widget.ContactApp.Button.Chip" parent="@style/Widget.ContactApp.Button.Base">
        <item name="android:minHeight">44dp</item>
        <item name="cornerRadius">22dp</item>
        <item name="android:background">@drawable/bg_chip_unselected</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/brand_text_primary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.ContactApp.EditText" parent="@style/Widget.AppCompat.EditText">
        <item name="android:fontFamily">@font/tasa</item>
        <item name="fontFamily">@font/tasa</item>
        <item name="android:textColor">@color/brand_text_primary</item>
        <item name="android:textColorHint">@color/brand_text_secondary</item>
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.ContactApp.AutoCompleteTextView" parent="@style/Widget.AppCompat.AutoCompleteTextView">
        <item name="android:fontFamily">@font/tasa</item>
        <item name="fontFamily">@font/tasa</item>
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textColor">@color/brand_text_primary</item>
        <item name="android:textColorHint">@color/brand_text_secondary</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.ContactApp.CheckBox" parent="@style/Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:fontFamily">@font/tasa</item>
        <item name="fontFamily">@font/tasa</item>
    </style>

    <style name="Widget.ContactApp.RadioButton" parent="@style/Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:fontFamily">@font/tasa</item>
        <item name="fontFamily">@font/tasa</item>
    </style>

    <style name="Widget.ContactApp.Switch" parent="@style/Widget.AppCompat.CompoundButton.Switch">
        <item name="android:fontFamily">@font/tasa</item>
        <item name="fontFamily">@font/tasa</item>
    </style>

    <style name="Widget.ContactApp.ScreenTitle" parent="@style/TextAppearance.ContactApp.HeadlineLarge" />
    <style name="Widget.ContactApp.SectionTitle" parent="@style/TextAppearance.ContactApp.TitleLarge" />
    <style name="Widget.ContactApp.SectionBody" parent="@style/TextAppearance.ContactApp.BodyMedium">
        <item name="android:textColor">@color/brand_text_secondary</item>
    </style>
    <style name="Widget.ContactApp.ListTitle" parent="@style/TextAppearance.ContactApp.TitleMedium" />
    <style name="Widget.ContactApp.ListBody" parent="@style/TextAppearance.ContactApp.BodyMedium">
        <item name="android:textColor">@color/brand_text_secondary</item>
    </style>
    <style name="Widget.ContactApp.Caption" parent="@style/TextAppearance.ContactApp.BodySmall" />

    <style name="ThemeOverlay.ContactApp.AlertDialog" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="android:windowBackground">@drawable/bg_dialog_surface</item>
        <item name="android:textColorPrimary">@color/brand_text_primary</item>
        <item name="android:textColorSecondary">@color/brand_text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.ContactApp.Button.Primary</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.ContactApp.Button.Secondary</item>
    </style>

    <style name="ThemeOverlay.ContactApp.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.ContactApp.Dialog</item>
        <item name="backgroundTint">@color/brand_background</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.ContactApp.TitleLarge</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.ContactApp.BodyMedium</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.ContactApp.Button.Primary</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.ContactApp.Button.Secondary</item>
    </style>

    <style name="ShapeAppearance.ContactApp.Dialog" parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

</resources>
