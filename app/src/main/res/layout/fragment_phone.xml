<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background"
    tools:context=".Fragments.PhoneFragment">

    <LinearLayout
        android:id="@+id/phoneHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dial"
            style="@style/Widget.ContactApp.ScreenTitle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Minimal keypad, adapted to your warm contact theme"
            style="@style/Widget.ContactApp.SectionBody" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/displayArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="24dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/phoneHeader">

        <TextView
            android:id="@+id/tvContactName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/brand_primary"
            android:visibility="gone"
            style="@style/Widget.ContactApp.ListBody"
            tools:text="Aarav Patel"
            tools:visibility="visible" />

        <EditText
            android:id="@+id/etPhoneNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:cursorVisible="false"
            android:focusable="false"
            android:fontFamily="@font/tasa"
            android:gravity="center"
            android:hint="Enter number"
            android:importantForAutofill="no"
            android:inputType="phone"
            android:letterSpacing="0.03"
            android:minHeight="72dp"
            android:textColor="@color/brand_text_primary"
            android:textColorHint="@color/brand_text_secondary"
            android:textSize="38sp"
            tools:text="9876543210" />

        <Button
            android:id="@+id/btnAddContact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Add to contacts"
            android:visibility="gone"
            style="@style/Widget.ContactApp.Button.Chip"
            tools:visibility="visible" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnBackspace"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_dialpad_key"
        android:contentDescription="Delete last digit"
        android:padding="12dp"
        android:src="@android:drawable/ic_input_delete"
        app:layout_constraintEnd_toEndOf="@id/displayArea"
        app:layout_constraintTop_toBottomOf="@id/displayArea"
        app:tint="@color/brand_text_primary" />

    <GridLayout
        android:id="@+id/dialpadGrid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="28dp"
        android:alignmentMode="alignMargins"
        android:columnCount="3"
        android:rowCount="4"
        android:useDefaultMargins="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBackspace">

        <TextView
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="1&#10;"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="2&#10;ABC"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/btn3"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="3&#10;DEF"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="4&#10;GHI"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/btn5"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="5&#10;JKL"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/btn6"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="6&#10;MNO"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/btn7"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="7&#10;PQRS"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/btn8"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="8&#10;TUV"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/btn9"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="9&#10;WXYZ"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/btnStar"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="*"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/btn0"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="0&#10;+"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/btnHash"
            android:layout_width="0dp"
            android:layout_height="86dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@drawable/bg_dialpad_key"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/tasa"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:text="#"
            android:textColor="@color/brand_text_primary"
            android:textSize="32sp" />

    </GridLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnCall"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="18dp"
        android:contentDescription="Call"
        android:src="@android:drawable/ic_menu_call"
        app:backgroundTint="@color/brand_primary"
        app:fabCustomSize="72dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dialpadGrid"
        app:tint="@color/brand_text_inverse" />

</androidx.constraintlayout.widget.ConstraintLayout>
