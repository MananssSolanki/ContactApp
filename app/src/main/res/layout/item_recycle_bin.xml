<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    app:cardBackgroundColor="@color/brand_surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/brand_border"
    app:strokeWidth="1dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="18dp">

        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp">

            <ImageView
                android:id="@+id/imgAvatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvAvatarLetter"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/circle_avatar_bg"
                android:gravity="center"
                android:textStyle="bold"
                style="@style/Widget.ContactApp.ListTitle" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                style="@style/Widget.ContactApp.ListTitle" />

            <TextView
                android:id="@+id/tvPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                style="@style/Widget.ContactApp.ListBody" />

            <TextView
                android:id="@+id/tvDaysLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/brand_error"
                style="@style/Widget.ContactApp.Caption" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/btnRestore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_secondary"
                android:gravity="center"
                android:minWidth="92dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:text="Restore"
                style="@style/TextAppearance.ContactApp.LabelMedium" />

            <TextView
                android:id="@+id/btnPermanentDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_dark"
                android:gravity="center"
                android:minWidth="92dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:text="Delete"
                android:textColor="@color/brand_text_inverse"
                style="@style/TextAppearance.ContactApp.LabelMedium" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
