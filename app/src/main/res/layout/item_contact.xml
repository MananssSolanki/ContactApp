<?xml version="1.0" encoding="utf-8"?>
<!--
    FIX NOTES:
    1. Removed android:padding from root — padding was colliding with adapter's setPadding() calls,
       causing double-padding. Padding is now handled purely in XML consistently.
    2. Kept android:background="?attr/selectableItemBackground" on root for ripple effect.
       The adapter no longer calls setBackgroundResource() on root, so ripple is preserved.
    3. editImg does NOT exist here — the adapter uses long-press for edit instead.
    4. tvPhoneNumber lives inside subLy — only visible when row is expanded (correct).
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="@dimen/_10sdp"
    android:paddingEnd="@dimen/_10sdp"
    android:paddingTop="@dimen/_10sdp"
    android:paddingBottom="@dimen/_10sdp">

    <LinearLayout
        android:id="@+id/parentLy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOP ROW: Avatar | Name | Favorite star -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Initial letter avatar (shown when no photo) -->
            <TextView
                android:id="@+id/tvContactInitial"
                android:layout_width="@dimen/_45sdp"
                android:layout_height="@dimen/_45sdp"
                android:background="@color/teal_200"
                android:gravity="center"
                android:text="A"
                android:textColor="@android:color/white"
                android:textSize="@dimen/_16ssp"
                android:textStyle="bold" />

            <!-- Contact photo (shown when photoUri is available) -->
            <ImageView
                android:id="@+id/ivContactPhoto"
                android:layout_width="@dimen/_45sdp"
                android:layout_height="@dimen/_45sdp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                tools:src="@mipmap/ic_launcher" />

            <!-- Contact name -->
            <TextView
                android:id="@+id/tvContactName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="@dimen/_14sdp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Contact Name"
                android:textColor="@android:color/black"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold" />

            <!-- Favorite star badge -->
            <ImageView
                android:id="@+id/ivFavorite"
                android:layout_width="@dimen/_16sdp"
                android:layout_height="@dimen/_16sdp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="@dimen/_4sdp"
                android:src="@android:drawable/btn_star_big_on"
                android:visibility="gone"
                android:contentDescription="Favorite" />

        </LinearLayout>

        <!-- EXPANDABLE SUB-PANEL (phone number + action buttons) -->
        <LinearLayout
            android:id="@+id/subLy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            android:layout_marginStart="@dimen/_45sdp"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Phone number (shown inside expanded panel) -->
            <TextView
                android:id="@+id/tvPhoneNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_14sdp"
                android:text="0000000000"
                android:textColor="@android:color/darker_gray"
                android:textSize="@dimen/_12ssp" />

            <!-- Action icon row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/_8sdp"
                android:layout_marginStart="@dimen/_14sdp">

                <!-- Call -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start">

                    <ImageView
                        android:id="@+id/phoneImg"
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        android:padding="@dimen/_4sdp"
                        android:src="@drawable/ic_call"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Call" />
                </LinearLayout>

                <!-- SMS -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start">

                    <ImageView
                        android:id="@+id/smsImg"
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        android:padding="@dimen/_4sdp"
                        android:src="@drawable/ic_sms"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="SMS" />
                </LinearLayout>

                <!-- Video Call -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start">

                    <ImageView
                        android:id="@+id/videoCallImg"
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        android:padding="@dimen/_4sdp"
                        android:src="@drawable/ic_video_call"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Video call" />
                </LinearLayout>

                <!-- Info / Details -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start">

                    <ImageView
                        android:id="@+id/informationImg"
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        android:padding="@dimen/_4sdp"
                        android:src="@drawable/ic_information"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Contact info" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>