<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/brand_surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/brand_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:id="@+id/parentLy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp">

                <TextView
                    android:id="@+id/tvContactInitial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_avatar_bg"
                    android:gravity="center"
                    android:text="A"
                    android:textColor="@color/brand_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivContactPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    tools:src="@mipmap/ic_launcher" />

                <ImageView
                    android:id="@+id/ivSelectionCheck"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_background"
                    android:backgroundTint="@color/brand_primary"
                    android:padding="12dp"
                    android:src="@android:drawable/checkbox_on_background"
                    android:visibility="gone"
                    app:tint="@color/brand_text_inverse" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvContactName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Contact Name"
                    style="@style/Widget.ContactApp.ListTitle" />

                <TextView
                    android:id="@+id/tvContactSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="0000000000"
                    style="@style/Widget.ContactApp.ListBody" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivFavorite"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Favorite"
                android:src="@android:drawable/btn_star_big_on"
                android:visibility="gone"
                app:tint="@color/brand_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/subLy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_soft"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvPhoneNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0000000000"
                style="@style/Widget.ContactApp.ListBody" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/phoneImg"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="Call"
                    android:padding="10dp"
                    android:src="@drawable/ic_call"
                    app:tint="@color/brand_primary" />

                <ImageView
                    android:id="@+id/smsImg"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="SMS"
                    android:padding="10dp"
                    android:src="@drawable/ic_sms"
                    app:tint="@color/brand_primary" />

                <ImageView
                    android:id="@+id/videoCallImg"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="Video call"
                    android:padding="10dp"
                    android:src="@drawable/ic_video_call"
                    app:tint="@color/brand_primary" />

                <ImageView
                    android:id="@+id/informationImg"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="Contact info"
                    android:padding="10dp"
                    android:src="@drawable/ic_information"
                    app:tint="@color/brand_text_primary" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
