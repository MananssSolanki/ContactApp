<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/_32sdp">

        <!-- ══ Account Selection Row ══ -->
        <LinearLayout
            android:id="@+id/layoutAccount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/_12sdp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground"
            android:layout_marginBottom="@dimen/_8sdp">

            <ImageView
                android:id="@+id/ivAccountIcon"
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:src="@drawable/ic_call"
                android:contentDescription="Account type" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/_12sdp">

                <TextView
                    android:id="@+id/tvAccountName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Google"
                    android:textColor="#333333"
                    android:textSize="@dimen/_14ssp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAccountEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="solankimanan19@gmail.com"
                    android:textColor="#666666"
                    android:textSize="@dimen/_11ssp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivAccountArrow"
                android:layout_width="@dimen/_18sdp"
                android:layout_height="@dimen/_18sdp"
                android:src="@android:drawable/arrow_down_float"
                app:tint="#888888"
                android:contentDescription="select account" />
        </LinearLayout>

        <!-- ══ Avatar ══ -->
        <FrameLayout
            android:layout_width="@dimen/_88sdp"
            android:layout_height="@dimen/_88sdp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/_24sdp"
            android:layout_marginBottom="@dimen/_20sdp">
            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="@dimen/_80sdp"
                android:layout_height="@dimen/_80sdp"
                android:src="@drawable/ic_launcher_foreground"
                android:scaleType="centerCrop"
                android:background="@drawable/circle_background"
                android:clipToOutline="true"
                android:layout_marginBottom="@dimen/_16sdp"/>
        </FrameLayout>

        <!-- ══════════════════════════════════════════
             NAME SECTION
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:padding="@dimen/_16sdp">

            <!-- Display name row with expand arrow -->
            <LinearLayout
                android:id="@+id/layoutNameExpand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="#666666"
                    android:contentDescription="name" />

                <EditText
                    android:id="@+id/etDisplayName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/_12sdp"
                    android:hint="Name"
                    android:textColorHint="#aaaaaa"
                    android:textColor="#333333"
                    android:background="@android:color/transparent"
                    android:textSize="@dimen/_16ssp"
                    android:inputType="textPersonName"
                    android:imeOptions="actionNext" />

                <ImageView
                    android:id="@+id/ivNameArrow"
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/arrow_up_float"
                    app:tint="#666666"
                    android:contentDescription="expand" />
            </LinearLayout>

            <!-- Expanded name fields -->
            <LinearLayout
                android:id="@+id/expandedNameFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#ddd" android:layout_marginVertical="@dimen/_8sdp" />

                <EditText android:id="@+id/etNamePrefix"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Name prefix" android:textColorHint="#aaaaaa"
                    android:textColor="#333333" android:background="@android:color/transparent"
                    android:textSize="@dimen/_15ssp" android:inputType="textPersonName"
                    android:layout_marginBottom="@dimen/_12sdp"/>

                <EditText android:id="@+id/etFirstName"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="First name" android:textColorHint="#aaaaaa"
                    android:textColor="#333333" android:background="@android:color/transparent"
                    android:textSize="@dimen/_15ssp" android:inputType="textPersonName"
                    android:layout_marginBottom="@dimen/_12sdp"/>

                <EditText android:id="@+id/etMiddleName"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Middle name" android:textColorHint="#aaaaaa"
                    android:textColor="#333333" android:background="@android:color/transparent"
                    android:textSize="@dimen/_15ssp" android:inputType="textPersonName"
                    android:layout_marginBottom="@dimen/_12sdp"/>

                <EditText android:id="@+id/etLastName"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Last name" android:textColorHint="#aaaaaa"
                    android:textColor="#333333" android:background="@android:color/transparent"
                    android:textSize="@dimen/_15ssp" android:inputType="textPersonName"
                    android:layout_marginBottom="@dimen/_12sdp"/>

                <EditText android:id="@+id/etNameSuffix"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Name suffix" android:textColorHint="#aaaaaa"
                    android:textColor="#333333" android:background="@android:color/transparent"
                    android:textSize="@dimen/_15ssp" android:inputType="textPersonName"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Phonetic name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:padding="@dimen/_16sdp"
            android:gravity="center_vertical">

            <ImageView android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                android:src="@android:drawable/ic_menu_myplaces" app:tint="#666666"
                android:contentDescription="phonetic"/>
            <EditText android:id="@+id/etPhoneticName"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_12sdp"
                android:hint="Phonetic name" android:textColorHint="#aaaaaa"
                android:textColor="#333333" android:background="@android:color/transparent"
                android:textSize="@dimen/_16ssp"/>
        </LinearLayout>

        <!-- Nickname -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_16sdp"
            android:padding="@dimen/_16sdp"
            android:gravity="center_vertical">

            <ImageView android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                android:src="@android:drawable/ic_menu_myplaces" app:tint="#666666"
                android:contentDescription="nickname"/>
            <EditText android:id="@+id/etNickname"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_12sdp"
                android:hint="Nickname" android:textColorHint="#aaaaaa"
                android:textColor="#333333" android:background="@android:color/transparent"
                android:textSize="@dimen/_16ssp"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             PHONE SECTION
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:padding="@dimen/_16sdp"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center_vertical">
                <ImageView android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_menu_call" app:tint="#666666"
                    android:contentDescription="phone"/>
                <LinearLayout android:id="@+id/phoneContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_12sdp" android:orientation="vertical"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="@dimen/_8sdp">
                <View android:layout_width="@dimen/_36sdp" android:layout_height="1dp"/>
                <ImageView android:id="@+id/btnAddPhone"
                    android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_input_add"
                    app:tint="#4CAF50"
                    android:layout_marginStart="@dimen/_12sdp"
                    android:contentDescription="Add phone"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Add phone number" android:textColor="#4CAF50"
                    android:layout_marginStart="@dimen/_8sdp" android:textSize="@dimen/_14ssp"
                    android:id="@+id/tvAddPhone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             EMAIL SECTION
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:padding="@dimen/_16sdp"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center_vertical">
                <ImageView android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_dialog_email" app:tint="#666666"
                    android:contentDescription="email"/>
                <LinearLayout android:id="@+id/emailContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_12sdp" android:orientation="vertical"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="@dimen/_8sdp">
                <View android:layout_width="@dimen/_36sdp" android:layout_height="1dp"/>
                <ImageView android:id="@+id/btnAddEmail"
                    android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_input_add"
                    app:tint="#4CAF50"
                    android:layout_marginStart="@dimen/_12sdp"
                    android:contentDescription="Add email"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Add email" android:textColor="#4CAF50"
                    android:layout_marginStart="@dimen/_8sdp" android:textSize="@dimen/_14ssp"
                    android:id="@+id/tvAddEmail"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             WORK INFO
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:padding="@dimen/_16sdp"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/_12sdp">
                <ImageView android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_menu_agenda" app:tint="#666666"
                    android:contentDescription="work"/>
                <EditText android:id="@+id/etJobTitle"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_12sdp"
                    android:hint="Job title" android:textColorHint="#aaaaaa"
                    android:textColor="#333333" android:background="@android:color/transparent"
                    android:textSize="@dimen/_16ssp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#ddd" android:layout_marginStart="@dimen/_36sdp" android:layout_marginBottom="@dimen/_12sdp"/>

            <EditText android:id="@+id/etDepartment"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_36sdp"
                android:hint="Department" android:textColorHint="#aaaaaa"
                android:textColor="#333333" android:background="@android:color/transparent"
                android:textSize="@dimen/_16ssp" android:layout_marginBottom="@dimen/_12sdp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#ddd" android:layout_marginStart="@dimen/_36sdp" android:layout_marginBottom="@dimen/_12sdp"/>

            <EditText android:id="@+id/etCompany"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_36sdp"
                android:hint="Company" android:textColorHint="#aaaaaa"
                android:textColor="#333333" android:background="@android:color/transparent"
                android:textSize="@dimen/_16ssp"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             ADDRESS SECTION
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:padding="@dimen/_16sdp"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center_vertical">
                <ImageView android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_menu_mapmode" app:tint="#666666"
                    android:contentDescription="address"/>
                <LinearLayout android:id="@+id/addressContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_12sdp" android:orientation="vertical"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="@dimen/_8sdp">
                <View android:layout_width="@dimen/_36sdp" android:layout_height="1dp"/>
                <ImageView android:id="@+id/btnAddAddress"
                    android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_input_add" app:tint="#4CAF50"
                    android:layout_marginStart="@dimen/_12sdp" android:contentDescription="Add address"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Add address" android:textColor="#4CAF50"
                    android:layout_marginStart="@dimen/_8sdp" android:textSize="@dimen/_14ssp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             IMPORTANT DATES
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:padding="@dimen/_16sdp"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center_vertical">
                <ImageView android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_menu_today" app:tint="#666666"
                    android:contentDescription="date"/>
                <LinearLayout android:id="@+id/dateContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_12sdp" android:orientation="vertical"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="@dimen/_8sdp">
                <View android:layout_width="@dimen/_36sdp" android:layout_height="1dp"/>
                <ImageView android:id="@+id/btnAddDate"
                    android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_input_add" app:tint="#4CAF50"
                    android:layout_marginStart="@dimen/_12sdp" android:contentDescription="Add date"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Add important date" android:textColor="#4CAF50"
                    android:layout_marginStart="@dimen/_8sdp" android:textSize="@dimen/_14ssp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             RELATIONSHIPS
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:padding="@dimen/_16sdp"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center_vertical">
                <ImageView android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_menu_share" app:tint="#666666"
                    android:contentDescription="relationship"/>
                <LinearLayout android:id="@+id/relationshipContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_12sdp" android:orientation="vertical"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="@dimen/_8sdp">
                <View android:layout_width="@dimen/_36sdp" android:layout_height="1dp"/>
                <ImageView android:id="@+id/btnAddRelationship"
                    android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_input_add" app:tint="#4CAF50"
                    android:layout_marginStart="@dimen/_12sdp" android:contentDescription="Add relationship"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Add relationship" android:textColor="#4CAF50"
                    android:layout_marginStart="@dimen/_8sdp" android:textSize="@dimen/_14ssp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             NOTES
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:padding="@dimen/_16sdp"
            android:gravity="center_vertical">

            <ImageView android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                android:src="@android:drawable/ic_menu_edit" app:tint="#666666"
                android:contentDescription="notes"/>
            <EditText android:id="@+id/etNotes"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_12sdp"
                android:hint="Notes" android:textColorHint="#aaaaaa"
                android:textColor="#333333" android:background="@android:color/transparent"
                android:textSize="@dimen/_16ssp" android:inputType="textMultiLine"
                android:minLines="1" android:gravity="top"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             WEBSITE
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:padding="@dimen/_16sdp"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center_vertical">
                <ImageView android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_menu_compass" app:tint="#666666"
                    android:contentDescription="website"/>
                <LinearLayout android:id="@+id/websiteContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_12sdp" android:orientation="vertical"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="@dimen/_8sdp">
                <View android:layout_width="@dimen/_36sdp" android:layout_height="1dp"/>
                <ImageView android:id="@+id/btnAddWebsite"
                    android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_input_add" app:tint="#4CAF50"
                    android:layout_marginStart="@dimen/_12sdp" android:contentDescription="Add website"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Add website" android:textColor="#4CAF50"
                    android:layout_marginStart="@dimen/_8sdp" android:textSize="@dimen/_14ssp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             MESSENGER / IM
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:layout_marginBottom="@dimen/_16sdp"
            android:padding="@dimen/_16sdp"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center_vertical">
                <ImageView android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_menu_send" app:tint="#666666"
                    android:contentDescription="messenger"/>
                <LinearLayout android:id="@+id/imContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_12sdp" android:orientation="vertical"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="@dimen/_8sdp">
                <View android:layout_width="@dimen/_36sdp" android:layout_height="1dp"/>
                <ImageView android:id="@+id/btnAddIm"
                    android:layout_width="@dimen/_24sdp" android:layout_height="@dimen/_24sdp"
                    android:src="@android:drawable/ic_input_add" app:tint="#4CAF50"
                    android:layout_marginStart="@dimen/_12sdp" android:contentDescription="Add account"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Add account" android:textColor="#4CAF50"
                    android:layout_marginStart="@dimen/_8sdp" android:textSize="@dimen/_14ssp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             BUTTONS
        ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:gravity="center">

            <Button android:id="@+id/btnCancel"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="@dimen/_48sdp"
                android:text="Cancel"
                android:textColor="#333333"
                android:backgroundTint="#EEEEEE"
                android:layout_marginEnd="@dimen/_8sdp"/>

            <Button android:id="@+id/btnSave"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="@dimen/_48sdp"
                android:text="Save"
                android:textColor="@android:color/white"
                android:backgroundTint="#1E90FF"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/_16sdp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
