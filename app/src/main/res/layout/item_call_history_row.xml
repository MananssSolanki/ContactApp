<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/brand_surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/brand_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="18dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_contact_photo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_foreground"
            android:visibility="visible"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <CheckBox
            android:id="@+id/cb_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/iv_call_type"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/sym_call_incoming"
            tools:tint="@color/brand_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8:53 pm"
                android:textColor="@color/brand_text_primary"
                android:visibility="gone"
                style="@style/Widget.ContactApp.ListTitle" />

            <TextView
                android:id="@+id/tv_contact_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Contact Name"
                android:visibility="gone"
                style="@style/Widget.ContactApp.ListTitle" />

            <TextView
                android:id="@+id/tv_phone_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="+1 234 567 8900"
                android:visibility="gone"
                style="@style/Widget.ContactApp.ListBody" />

            <TextView
                android:id="@+id/tv_status_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Incoming call, 0 mins 8 secs"
                android:visibility="gone"
                style="@style/Widget.ContactApp.Caption" />

            <TextView
                android:id="@+id/tv_time_and_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="10:30 AM • 2:45"
                android:visibility="gone"
                style="@style/Widget.ContactApp.Caption" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_call"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="Call"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_call"
            android:visibility="gone"
            app:tint="@color/brand_primary" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="74dp"
        android:background="@drawable/divider_premium"
        android:visibility="gone" />

</com.google.android.material.card.MaterialCardView>
