<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="68dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="12dp"
    android:background="@android:color/transparent">

    <!-- Circle Avatar frame -->
    <FrameLayout
        android:layout_width="46dp"
        android:layout_height="46dp">

        <!-- Letter fallback circle -->
        <TextView
            android:id="@+id/tvAvatarLetter"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:gravity="center"
            android:textSize="18sp"
            android:textColor="@color/samsung_card_white"
            android:textStyle="bold"
            android:background="@drawable/bg_circle_avatar" />

        <!-- Contact photo -->
        <ImageView
            android:id="@+id/imgContactAvatar"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Name + phone number -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/tvContactName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/samsung_title_text"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvContactPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/samsung_gray_text"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Default badge (shown only on 1st contact in group) -->
    <LinearLayout
        android:id="@+id/layoutDefault"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="gone">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_merge"
            app:tint="@color/samsung_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Default"
            android:textSize="11sp"
            android:textColor="@color/samsung_blue" />
    </LinearLayout>

</LinearLayout>
