<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Custom Samsung-style Toolbar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/black" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/btnBack"
            android:text="Import contacts"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
        android:fontFamily="@font/tasa" />
    </RelativeLayout>

    <ViewAnimator
        android:id="@+id/viewAnimator"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:inAnimation="@android:anim/fade_in"
        android:outAnimation="@android:anim/fade_out">

        <!-- Step 1: FROM Selection -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="From"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold"
        android:fontFamily="@font/tasa" />

                <LinearLayout
                    android:id="@+id/layoutFromSelection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_samsung_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingBottom="12dp"
                        android:text="Select where to import your contacts from."
                        android:textColor="#757575"
                        android:textSize="14sp"
        android:fontFamily="@font/tasa" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvFromAccounts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="#DCDCDC" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="To"
                    android:textColor="#BFBFBF"
                    android:textSize="22sp"
                    android:textStyle="bold"
        android:fontFamily="@font/tasa" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_samsung_card"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select where to import these contacts to."
                        android:textColor="#BFBFBF"
                        android:textSize="14sp"
        android:fontFamily="@font/tasa" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Step 2: CONTACT Selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:padding="16dp">

                <CheckBox
                    android:id="@+id/cbSelectAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
        android:fontFamily="@font/tasa" />

                <TextView
                    android:id="@+id/tvSelectionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="0 selected"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
        android:fontFamily="@font/tasa" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvContactsToImport"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btnDoneSelection"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_margin="16dp"
                android:background="@drawable/bg_samsung_button"
                android:text="Done"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
        android:fontFamily="@font/tasa" />
        </LinearLayout>

        <!-- Step 3: TO Selection -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="From"
                    android:textColor="#BFBFBF"
                    android:textSize="22sp"
                    android:textStyle="bold"
        android:fontFamily="@font/tasa" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_samsung_card"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_centerInParent="true"
                        app:srcCompat="@drawable/ic_check_circle"
                        app:tint="#00BCD4" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvSelectedFromName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SIM 2"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold"
        android:fontFamily="@font/tasa" />

                        <TextView
                            android:id="@+id/tvSelectedFromCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6 contacts"
                            android:textColor="#00BCD4"
                            android:textSize="13sp"
        android:fontFamily="@font/tasa" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"
                    android:src="@drawable/ic_arrow_down"
                    app:tint="#DCDCDC" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="To"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold"
        android:fontFamily="@font/tasa" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_samsung_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingBottom="12dp"
                        android:text="Select where to import these contacts to."
                        android:textColor="#757575"
                        android:textSize="14sp"
        android:fontFamily="@font/tasa" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvToAccounts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnImport"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_samsung_button"
                    android:text="Import"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:visibility="gone"
        android:fontFamily="@font/tasa" />

            </LinearLayout>
        </ScrollView>

        <!-- Step 4: SUCCESS Screen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:id="@+id/tvSuccessMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Contacts added to your Google"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:textStyle="bold"
        android:fontFamily="@font/tasa" />

            <RelativeLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="64dp"
                android:layout_marginBottom="64dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_background"
                    android:backgroundTint="#EBFCFE" />

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_check_circle"
                    app:tint="#00BCD4" />
            </RelativeLayout>

            <Button
                android:id="@+id/btnSuccessOk"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_samsung_button"
                android:text="OK"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
        android:fontFamily="@font/tasa" />

        </LinearLayout>

    </ViewAnimator>

</LinearLayout>